# Variables de Entorno - Hotel Paraiso
# Copia este archivo como .env y configura tus variables

# Configuración de la aplicación
APP_NAME=Hotel Paraiso
APP_ENV=development
APP_DEBUG=true

# Configuración de Base de Datos
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=hotel_paraiso
DB_USERNAME=root
DB_PASSWORD=

# Configuración de Email (si lo necesitas)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_password
MAIL_FROM_ADDRESS=noreply@hotelparaiso.com
MAIL_FROM_NAME="${APP_NAME}"

# Configuración de URL
APP_URL=http://localhost/hotel.paraiso-main

# Zona horaria
APP_TIMEZONE=America/Mexico_City

# API Keys (si lo necesitas)
GOOGLE_MAPS_API_KEY=
STRIPE_API_KEY=
STRIPE_SECRET_KEY=
